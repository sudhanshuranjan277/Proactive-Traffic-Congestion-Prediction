<?xml version="1.0" encoding="UTF-8"?>

<routes>

    <!-- Vehicle Type -->
    <vType id="car"
           accel="2.6"
           decel="4.5"
           sigma="0.5"
           length="5"
           minGap="2.5"
           maxSpeed="20"
           color="1,0,0"/>

    <!-- Routes -->
    <route id="north_south" edges="N2C C2S"/>
    <route id="south_north" edges="S2C C2N"/>
    <route id="east_west" edges="E2C C2W"/>
    <route id="west_east" edges="W2C C2E"/>

    <!-- Traffic Flows -->

    <flow id="flow_NS"
          type="car"
          route="north_south"
          begin="0"
          end="3600"
          vehsPerHour="600"/>

    <flow id="flow_SN"
          type="car"
          route="south_north"
          begin="0"
          end="3600"
          vehsPerHour="600"/>

    <flow id="flow_EW"
          type="car"
          route="east_west"
          begin="0"
          end="3600"
          vehsPerHour="600"/>

    <flow id="flow_WE"
          type="car"
          route="west_east"
          begin="0"
          end="3600"
          vehsPerHour="600"/>

</routes>